# WhereRat — environment variables reference
#
# Copy to .env.local and fill in values from Vercel dashboard:
#   cp .env.example .env.local
#
# All secrets live in Vercel → Project → Settings → Environment Variables.
# This file is the canonical reference for what the app needs — keep it in sync.
# Never commit real values here.

# ── Database (required) ───────────────────────────────────────────────────────
# Neon Postgres connection string. Get from Neon dashboard or Vercel.
# src/lib/db.ts also accepts POSTGRES_URL / POSTGRES_PRISMA_URL as fallbacks.
DATABASE_URL=

# ── Moderator auth (required in production) ───────────────────────────────────
# HMAC-SHA256 key for signing session cookies. Generate with:
#   openssl rand -base64 48
SESSION_SECRET=

# Password for the admin moderator account (/login → username: admin).
# If unset in production, auth.ts generates a random UUID on each cold start
# (i.e. you won't be able to log in). Generate with: openssl rand -base64 18
MODERATOR_ADMIN_PASSWORD=

# ── Cron sync (required if using /api/cron/imdb-resync) ──────────────────────
# Bearer token used by Vercel Cron to authenticate to the resync endpoint.
# Generate with: openssl rand -base64 32
CRON_SECRET=

# ── Movie metadata (recommended) ─────────────────────────────────────────────
# OMDb API key — powers movie search in the submit form and IMDb metadata sync.
# Get a free key at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# TMDB read-only access token — used for backdrop images.
# Get from https://www.themoviedb.org/settings/api
TMDB_READ_ACCESS_TOKEN=

# ── Image storage (required for uploads to persist) ──────────────────────────
# Vercel Blob token — required for sighting image uploads to survive deploys.
# Without this, images are written to local disk and lost on each deployment.
#
# To set up:
#   1. Vercel dashboard → Project → Storage → Create → Blob
#   2. Copy BLOB_READ_WRITE_TOKEN from the store's settings
#   3. Add it here and to Vercel env vars
BLOB_READ_WRITE_TOKEN=
