# Copy to `.env.local` (local) — never commit real secrets.
#   cp .env.example .env.local
#
# Hosted (e.g. Vercel): set the same keys in Project → Settings → Environment Variables
# for every environment you use (Production, Preview, Development).

# Required for Postgres-backed routes (/api/v1/*, catalog pages, moderator flows, scripts).
# `src/lib/db.ts` accepts DATABASE_URL first, then POSTGRES_URL / POSTGRES_PRISMA_URL / DATABASE_URL_UNPOOLED.
DATABASE_URL=

# Moderator login (see src/lib/auth.ts)
# MODERATOR_ADMIN_PASSWORD=
# MODERATOR_PASSWORD=
# SESSION_SECRET=

# Movie search / imagery (optional)
# TMDB_READ_ACCESS_TOKEN=
# OMDB_API_KEY=

# Ver submissions / blobs (when used)
# BLOB_READ_WRITE_TOKEN=

# S3 uploads (optional; see README)
# AWS_REGION=
# S3_BUCKET_NAME=
# S3_PUBLIC_BASE_URL=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
UPLOAD_FALLBACK_TO_LOCAL=true
