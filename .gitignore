# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local prototype data
/data/*.json

# vercel
.vercel

# claude code
.claude/*
!.claude/settings.json

# yarn 4 (not tracked in this repo)
.yarnrc.yml
yarn.lock

# user-uploaded sighting images (prototype)
/public/uploads/sightings/*
!/public/uploads/sightings/.gitkeep

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local
