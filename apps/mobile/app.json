{
  "expo": {
    "name": "WhereRat",
    "slug": "whererat",
    "scheme": "whererat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ea580c"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.whererat.app",
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": true,
        "NSPhotoLibraryUsageDescription": "Allow WhereRat to choose images for sightings.",
        "NSCameraUsageDescription": "Allow WhereRat to take photos for sightings."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ea580c"
      },
      "package": "com.whererat",
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow WhereRat to choose images for sightings.",
          "cameraPermission": "Allow WhereRat to take photos for sightings."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7ce556ec-1c86-4a6b-ac05-10e1bc11b02b"
      }
    },
    "owner": "mikekuzin"
  }
}
