{
  "name": "mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "bash scripts/run-android.sh",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "generate-assets": "bash scripts/generate-mobile-assets.sh",
    "eas": "npx eas-cli@latest",
    "eas:login": "npx eas-cli@latest login",
    "eas:whoami": "npx eas-cli@latest whoami",
    "eas:build:android": "npx eas-cli@latest build --platform android --profile production",
    "eas:build:ios": "npx eas-cli@latest build --platform ios --profile production",
    "eas:submit:android": "npx eas-cli@latest submit --platform android --latest",
    "deploy": "npx expo export -p web && npx eas-cli@latest deploy",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "expo": "^54.0.1",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.0",
    "expo-splash-screen": "~31.0.13",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-image-colors": "^2.6.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0"
  },
  "private": true,
  "devDependencies": {
    "@types/react": "^19.2.14",
    "patch-package": "^8.0.1",
    "typescript": "^5.9.3"
  }
}
